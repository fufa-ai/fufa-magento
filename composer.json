{
    "name": "fufa/module-webhook",
    "description": "Magento 2 module to send order, shipment, refund, and abandoned cart events to external webhooks with HMAC-SHA256 signatures.",
    "type": "magento2-module",
    "license": [
        "GPL-3.0-or-later"
    ],
    "authors": [
        {
            "name": "Fufa",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1 || ^8.2 || ^8.3",
        "magento/framework": "^103.0"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Fufa\\Webhook\\": ""
        }
    },
    "extra": {
        "map": [
            [
                "*",
                "Fufa/Webhook"
            ]
        ]
    }
}